{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "NutriHub@SuperSecretKey#2026!XyZ987",
    "Issuer": "NutriHub.IdentityService",
    "Audience": "NutriHub.Client",
    "ExpiryMinutes": "60"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "category-route": {
        "ClusterId": "category-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        },
        "HttpRequest": {
          "Version": "1.1"
        }
      },
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        },
        "HttpRequest": {
          "Version": "1.1"
        }
      },
      "category-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        },
        "HttpRequest": {
          "Version": "1.1"
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        },
        "HttpRequest": {
          "Version": "1.1"
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        },
        "HttpRequest": {
          "Version": "1.1"
        }
      }
    }
  }
}
